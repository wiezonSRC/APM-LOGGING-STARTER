<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 기본 스프링 부트 로그 설정 상속 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <!-- 1. 테스트용 콘솔 어펜더 설정: [%marker] 패턴 추가 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%marker] %logger{36} - %msg%n</pattern>
        </encoder>
        <filter class="com.company.logging.core.support.logback.MetricMarkerFilter">
            <acceptIfMarkerPresent>true</acceptIfMarkerPresent>
        </filter>
    </appender>

    <!-- 2. "Log" 로거 설정 -->
    <logger name="Log" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- 3. 기본 루트 로거 설정 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
